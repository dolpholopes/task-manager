{
  "entities": {
    "Workspace": {
      "title": "Workspace",
      "description": "Represents a collection of cards and tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "ownerId": { "type": "string" },
        "inviteCode": { "type": "string" },
        "order": { "type": "integer" },
        "createdAt": { "type": "integer" }
      },
      "required": ["id", "title", "ownerId", "order", "createdAt"]
    },
    "WorkspaceMember": {
      "title": "Workspace Member",
      "description": "A user that has access to a workspace",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "editor", "viewer"] },
        "joinedAt": { "type": "integer" }
      },
      "required": ["userId", "role", "joinedAt"]
    },
    "Invite": {
      "title": "Invite Code",
      "description": "A code used to join a workspace",
      "type": "object",
      "properties": {
        "workspaceId": { "type": "string" },
        "code": { "type": "string" },
        "role": { "type": "string", "enum": ["editor", "viewer"] }
      },
      "required": ["workspaceId", "code", "role"]
    },
    "Card": {
      "title": "Card",
      "description": "A column or vertical group of tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "viewMode": { "type": "string", "enum": ["card", "list"] },
        "order": { "type": "integer" },
        "workspaceId": { "type": "string" }
      },
      "required": ["id", "title", "workspaceId"]
    },
    "Task": {
      "title": "Task",
      "description": "A single to-do item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "reminder": { "type": "string" },
        "reminderSent": { "type": "boolean" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "integer" },
        "cardId": { "type": "string" },
        "workspaceId": { "type": "string" },
        "order": { "type": "integer" },
        "labelId": { "type": "string" },
        "assigneeId": { "type": "string" }
      },
      "required": ["id", "title", "priority", "completed", "cardId", "workspaceId", "order"]
    },
    "Label": {
      "title": "Label",
      "description": "A custom tag for tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "color"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "A member that can be assigned to tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["id", "name", "color"]
    },
    "Automation": {
      "title": "Automation",
      "description": "A rule that triggers an action on tasks",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "trigger": { "type": "string" },
        "triggerCardId": { "type": "string" },
        "triggerMemberId": { "type": "string" },
        "action": { "type": "string" },
        "actionLabelId": { "type": "string" },
        "actionMemberId": { "type": "string" },
        "enabled": { "type": "boolean" }
      },
      "required": ["id", "name", "trigger", "action", "enabled"]
    }
  },
  "firestore": {
    "/workspaces/{workspaceId}": {
      "schema": "Workspace",
      "description": "Global workspaces"
    },
    "/workspaces/{workspaceId}/members/{userId}": {
      "schema": "WorkspaceMember",
      "description": "Workspace members and roles"
    },
    "/workspaces/{workspaceId}/cards/{cardId}": {
      "schema": "Card",
      "description": "Cards within a workspace"
    },
    "/workspaces/{workspaceId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks within a workspace"
    },
    "/workspaces/{workspaceId}/labels/{labelId}": {
      "schema": "Label",
      "description": "Labels within a workspace"
    },
    "/workspaces/{workspaceId}/automations/{automationId}": {
      "schema": "Automation",
      "description": "Automations within a workspace"
    },
    "/workspaces/{workspaceId}/team_members/{memberId}": {
      "schema": "TeamMember",
      "description": "Team members within a workspace"
    },
    "/users/{userId}/memberships/{workspaceId}": {
      "schema": "WorkspaceMember",
      "description": "Redundant member data for fast querying of a user's workspaces"
    },
    "/invites/{code}": {
      "schema": "Invite",
      "description": "Active invite codes"
    }
  }
}
